# Contextarium environment template.
# Copy this file to .env and fill only the values you need.

# Cloud embedding mode.
OPENAI_API_KEY=

# Optional remote reranking in cloud mode.
DEEPINFRA_API_KEY=

# Optional server overrides.
APP_HOST=127.0.0.1
APP_PORT=8000
MCP_HTTP_PATH=/mcp
LOG_LEVEL=INFO

# Optional OpenAI client tuning for cloud embeddings.
OPENAI_TIMEOUT_SEC=45
OPENAI_MAX_RETRIES=2

# Docker restart support from the web panel.
CONTAINER_NAME=contextarium-tools
DOCKER_RESTART_TIMEOUT_SEC=30
